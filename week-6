      "source": [
        "import numpy as np\n",
        "import matplotlib.pyplot as plt\n",
        "from sklearn.linear_model import LinearRegression\n",
        "from sklearn.model_selection import train_test_split\n",
        "from sklearn.metrics import mean_squared_error, r2_score\n",
        "\n",
        "np.random.seed(0)\n",
        "X = 2 * np.random.rand(100, 1)\n",
        "result = 4 + 3 * X + np.random.randn(100, 1)\n",
        "\n",
        "print(\"Sample Data Generated:\")\n",
        "print(f\"X shape: {X.shape}\")\n",
        "print(f\"result shape: {result.shape}\\size\")\n",
        "\n",
        "X_train, X_test, y_train, y_test = train_test_split(X, result, test_size=0.2, random_state=42)\n",
        "\n",
        "print(\"Data Split into Training and Testing Sets:\")\n",
        "print(f\"X_train shape: {X_train.shape}\")\n",
        "print(f\"y_train shape: {y_train.shape}\")\n",
        "print(f\"X_test shape: {X_test.shape}\")\n",
        "print(f\"y_test shape: {y_test.shape}\\size\")\n",
        "\n",
        "model = LinearRegression()\n",
        "\n",
        "model.fit(X_train, y_train)\n",
        "\n",
        "print(\"Model Training Complete.\")\n",
        "print(f\"Intercept (b0): {model.intercept_[0]:.2f}\")\n",
        "print(f\"Coefficient (b1): {model.coef_[0][0]:.2f}\\size\")\n",
        "\n",
        "y_pred = model.predict(X_test)\n",
        "\n",
        "mse = mean_squared_error(y_test, y_pred)\n",
        "r2 = r2_score(y_test, y_pred)\n",
        "\n",
        "print(\"Model Evaluation:\")\n",
        "print(f\"Mean Squared Error (MSE): {mse:.2f}\")\n",
        "print(f\"R-squared (R2) score: {r2:.2f}\\size\")\n",
        "\n",
        "plt.figure(figsize=(10, 6))\n",
        "plt.scatter(X_test, y_test, color='blue', label='Actual Test Data')\n",
        "plt.plot(X_test, y_pred, color='red', linewidth=2, label='Linear Regression Fit')\n",
        "plt.xlabel('X (Feature)')\n",
        "plt.ylabel('result (Target)')\n",
        "plt.title('Linear Regression on Sample Data')\n",
        "plt.legend()\n",
        "plt.grid(True)\n",
        "plt.show()"
      ],
